{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Android Toolkit Beta",
  "version": "3.0.0-beta",
  "identifier": "com.teamnocturnal.toolkit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Android Toolkit Beta",
        "width": 1600,
        "height": 1020,
        "minWidth": 1320,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/adb",
      "binaries/fastboot"
    ],
    "resources": {
      "binaries/AdbWinApi.dll": "AdbWinApi.dll",
      "binaries/AdbWinUsbApi.dll": "AdbWinUsbApi.dll"
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "dmg": {
        "background": "images/dmg-background.png"
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
